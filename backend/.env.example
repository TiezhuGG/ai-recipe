# Backend development environment template
# Local development keeps SQLite. Production should switch to PostgreSQL.

LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api-inference.modelscope.cn/v1
MODEL_NAME=Qwen/Qwen3.5-35B-A3B

DATABASE_URL=sqlite:///./dev.db
# Production PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://recipe_user:your_password@localhost:5432/recipe_db

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

SECRET_KEY=replace_with_a_random_32_plus_char_secret

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE=2592000

LOG_LEVEL=INFO
API_TIMEOUT=120
API_MAX_RETRIES=2
APP_ENV=development
UVICORN_WORKERS=1
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

