# Root Docker Compose environment template

POSTGRES_DB=recipe_db
POSTGRES_USER=recipe_user
POSTGRES_PASSWORD=replace_with_a_strong_postgres_password
DATABASE_URL=postgresql+psycopg://recipe_user:replace_with_a_strong_postgres_password@db:5432/recipe_db

LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api-inference.modelscope.cn/v1
MODEL_NAME=Qwen/Qwen3.5-35B-A3B

SECRET_KEY=replace_with_a_random_32_plus_char_secret
APP_ENV=production

CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE=2592000

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

LOG_LEVEL=INFO
API_TIMEOUT=120
API_MAX_RETRIES=2
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
UVICORN_WORKERS=2

# Leave empty to use same-origin nginx reverse proxy in the frontend container.
VITE_API_BASE_URL=

